export function normalizeLanguage(value: string | undefined): AppLanguage {
  return value === 'en' ? 'en' : DEFAULT_LANGUAGE;
}

export function translate(language: AppLanguage, key: string): string {
  const bundle = language === 'en' ? EN_TRANSLATIONS : ZH_TRANSLATIONS;
  return bundle[key] ?? EN_TRANSLATIONS[key] ?? key;
}

export function formatTranslation(language: AppLanguage, key: string, names: Array<string>, values: Array<string>): string {
  let result = translate(language, key);
  for (let index = 0; index < names.length; index++) {
    const name = names[index];
    result = result.split(`{${name}}`).join(values[index] ?? '');
  }
  return result;
}

export function missingTranslationKeys(language: AppLanguage): Array<string> {
  const missing: Array<string> = [];
  for (let index = 0; index < TRANSLATION_KEYS.length; index++) {
    const key = TRANSLATION_KEYS[index];
    if (translate(language, key) === key) {
      missing.push(key);
    }
  }
  return missing;
}
